{
  "apps": [
    {
      "name": "imap-993",
      "script": "imap.js",
      "exec_mode": "cluster",
      "wait_ready": true,
      "instances": "max",
      "pmx": false,
      "env_production": {
        "NODE_ENV": "production",
        "IMAP_PORT": 993
      }
    },
    {
      "name": "imap-2993",
      "script": "imap.js",
      "exec_mode": "fork",
      "wait_ready": true,
      "instances": "1",
      "pmx": false,
      "env_production": {
        "NODE_ENV": "production",
        "IMAP_PORT": 2993
      }
    },
    {
      "name": "imap-2143",
      "script": "imap.js",
      "exec_mode": "fork",
      "wait_ready": true,
      "instances": "1",
      "pmx": false,
      "node_args": "--tls-min-v1.0 --tls-cipher-list=DEFAULT@SECLEVEL=0",
      "env_production": {
        "NODE_ENV": "production",
        "IMAP_PORT": 2143,
        "IMAP_TLS_MIN_VERSION": "TLSv1"
      }
    },
    {
      "name": "managesieve-4190",
      "script": "managesieve.js",
      "exec_mode": "cluster",
      "wait_ready": true,
      "instances": "max",
      "pmx": false,
      "env_production": {
        "NODE_ENV": "production",
        "MANAGESIEVE_PORT": 4190
      }
    }
  ],
  "deploy": {
    "production": {
      "user": "deploy",
      "host": [{% for host in groups['imap'] %}"{{ hostvars[host].ansible_host }}"{% if not loop.last %}, {% endif %}{% endfor %}],
      "ref": "origin/master",
      "repo": "{{ lookup('env', 'GITHUB_REPO') }}",
      "path": "/var/www/production",
      "pre-deploy": "git reset --hard",
      "post-deploy": "bash ./scripts/pm2-post-deploy.sh ecosystem-imap.json production"
    }
  }
}
