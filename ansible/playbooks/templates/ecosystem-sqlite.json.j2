{
  "apps": [
    {
      "name": "sqlite",
      "script": "sqlite.js",
      "wait_ready": true,
      "exec_mode": "cluster",
      "instances": "max",
      "pmx": false,
      "env_production": {
        "NODE_ENV": "production"
      }
    },
    {
      "name": "sqlite-bree",
      "script": "sqlite-bree.js",
      "exec_mode": "fork",
      "wait_ready": true,
      "instances": "1",
      "pmx": false,
      "env_production": {
        "NODE_ENV": "production"
      }
    }
  ],
  "deploy": {
    "production": {
      "user": "deploy",
      "host": [{% for host in groups['sqlite'] %}"{{ hostvars[host].ansible_host }}"{% if not loop.last %}, {% endif %}{% endfor %}],
      "ref": "origin/master",
      "repo": "{{ lookup('env', 'GITHUB_REPO') }}",
      "path": "/var/www/production",
      "pre-deploy": "git reset --hard",
      "post-deploy": "PNPM_VERSION=$(node -p \"require('./package.json').packageManager.match(/^pnpm@(.*)$/)[1]\") && npm install -g \"pnpm@$PNPM_VERSION\" && hash -r && pnpm install --frozen-lockfile && NODE_ENV=production npm start build && pm2 startOrGracefulReload ecosystem-sqlite.json --env production --update-env"
    }
  }
}
