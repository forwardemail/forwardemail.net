{
  "apps": [
    {
      "name": "sqlite",
      "script": "sqlite.js",
      "wait_ready": true,
      "listen_timeout": 10000,
      "exec_mode": "fork",
      "instances": 10,
      "pmx": false,
      "env_production": {
        "NODE_ENV": "production"
      }
    },
    {
      "name": "sqlite-bree",
      "script": "sqlite-bree.js",
      "exec_mode": "fork",
      "wait_ready": true,
      "instances": "1",
      "pmx": false,
      "env_production": {
        "NODE_ENV": "production"
      }
    },
    {
      "name": "sqlite-worker",
      "script": "sqlite-worker.js",
      "exec_mode": "fork",
      "wait_ready": true,
      "instances": "1",
      "pmx": false,
      "env_production": {
        "NODE_ENV": "production"
      }
    }
  ],
  "deploy": {
    "production": {
      "user": "deploy",
      "host": [{% for host in groups['sqlite'] %}"{{ hostvars[host].ansible_host }}"{% if not loop.last %}, {% endif %}{% endfor %}],
      "ref": "origin/master",
      "repo": "{{ lookup('env', 'GITHUB_REPO') }}",
      "path": "/var/www/production",
      "pre-deploy": "git reset --hard",
      "post-deploy": "bash ./scripts/pm2-post-deploy.sh ecosystem-sqlite.json production"
    }
  }
}
