FROM node:20-slim AS builder

WORKDIR /app

ENV SELF_HOSTED=true

RUN corepack enable && corepack prepare pnpm@9.15.9 --activate

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . ./
ENV NODE_ENV=production
RUN pnpm run build

## build everything in the first stage and then
## leverage .dockerignore and 2nd stage to remove files
## from the built image that we don't want included
FROM node:20-slim

WORKDIR /app

ENV SELF_HOSTED=true
ENV NODE_ENV=production

RUN apt-get update && apt-get install -y --no-install-recommends \
    dnsutils netcat-traditional curl openssl ca-certificates && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# TODO: this needs to come from or sync with env file (e.g. SQLITE_TMPDIR)
RUN mkdir -p /mnt/sqlite_storage

COPY --from=builder /app /app

# Create a non-root user and set ownership
RUN groupadd -r forwardemail && useradd -r -g forwardemail -d /app forwardemail && \
    chown -R forwardemail:forwardemail /app /mnt/sqlite_storage

USER forwardemail
