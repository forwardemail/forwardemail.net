package-lock=true
strict-peer-dependencies=false
save-exact=true
prefer-frozen-lockfile=true
audit-level=moderate

# Supply-chain protection (https://gajus.com/blog/3-pnpm-settings-to-protect-yourself-from-supply-chain-attacks)
# Quarantine newly published packages for 7 days (10080 minutes); pnpm <10 reads from .npmrc
minimum-release-age=10080
# Block subdependencies that use exotic specifiers (git:, tarball URLs, etc.); pnpm <10 reads from .npmrc
block-exotic-subdeps=true
