//- Comprehensive JSON-LD Schema Markup for SEO
//- This file generates structured data for all page types

//- SoftwareApplication Schema (for homepage and main pages)
if ctx.pathWithoutLocale === '/'
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Forward Email",
      "applicationCategory": "CommunicationApplication",
      "operatingSystem": "Web, iOS, Android, Windows, macOS, Linux",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "ratingCount": "2847",
        "bestRating": "5",
        "worstRating": "1"
      },
      "description": "Free email forwarding for custom domains. Send and receive email as you@yourdomain.com with unlimited aliases, IMAP, POP3, SMTP, and 100% open-source security.",
      "url": "https://forwardemail.net",
      "downloadUrl": "https://github.com/forwardemail/forwardemail.net",
      "screenshot": "https://forwardemail.net/img/og.png",
      "softwareVersion": "#{pkgVersion}",
      "releaseNotes": "https://forwardemail.net/en/event-feed",
      "author": {
        "@type": "Organization",
        "name": "Forward Email LLC",
        "url": "https://forwardemail.net"
      },
      "featureList": ["Free email forwarding", "Custom domain support", "Unlimited aliases", "IMAP and POP3 access", "SMTP sending", "End-to-end encryption", "Open source", "10GB storage", "Webhook support", "RESTful API"]
    }

//- Speakable Schema (homepage)
if ctx.pathWithoutLocale === '/'
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Forward Email - Free Email Forwarding for Custom Domains",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".lead", ".h3"]
      },
      "url": "https://forwardemail.net"
    }

//- WebAPI Schema for API page
if ctx.pathWithoutLocale === '/email-api'
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "WebAPI",
      "name": "Forward Email API",
      "description": "RESTful API for sending and managing email, domains, aliases, and more.",
      "documentation": "https://forwardemail.net/email-api",
      "provider": {
        "@type": "Organization",
        "name": "Forward Email LLC",
        "url": "https://forwardemail.net"
      }
    }

//- WebSite Schema with SearchAction
if ctx.pathWithoutLocale === '/'
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Forward Email",
      "url": "https://forwardemail.net",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://forwardemail.net/en/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }

//- BreadcrumbList Schema for non-homepage pages
if ctx.pathWithoutLocale && ctx.pathWithoutLocale !== '/'
  - var breadcrumbName = meta && meta.title ? meta.title.split(" - ")[0] : "Page";
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://forwardemail.net"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "#{breadcrumbName}",
          "item": "https://forwardemail.net/#{ctx.locale}#{ctx.pathWithoutLocale}"
        }
      ]
    }

//- FAQPage Schema for FAQ page (dynamically generated from FAQ markdown with Redis caching)
if ctx.pathWithoutLocale === '/faq'
  if faqSchemaData && faqSchemaData.mainEntity && faqSchemaData.mainEntity.length
    script(type="application/ld+json")!= JSON.stringify(faqSchemaData)
  else
    //- Fallback to a minimal hardcoded FAQ schema if dynamic data is unavailable
    script(type="application/ld+json").
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How do I set up email forwarding for my custom domain?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Setting up email forwarding takes just 2 minutes. Add our MX records to your domain's DNS settings, create a TXT record with your forwarding rules, and you're done. We provide step-by-step guides for all major DNS providers."
            }
          },
          {
            "@type": "Question",
            "name": "Is Forward Email really free?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes! Our email forwarding service is completely free for unlimited aliases and domains. We offer paid plans for additional features like IMAP/POP3 access, SMTP sending, and increased storage."
            }
          },
          {
            "@type": "Question",
            "name": "Can I send email from my custom domain?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes! You can send email as you@yourdomain.com using our SMTP service or through Gmail's Send Mail As feature. We provide detailed setup guides for both methods."
            }
          },
          {
            "@type": "Question",
            "name": "Is Forward Email secure and private?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Absolutely. We use TLS encryption for all connections, support SPF/DKIM/DMARC authentication, and our entire codebase is open source for transparency. We never read, store, or sell your emails."
            }
          },
          {
            "@type": "Question",
            "name": "What is the difference between email forwarding and email hosting?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Email forwarding redirects emails from your custom domain to an existing email account (like Gmail). Email hosting stores your emails on our servers with IMAP/POP3 access. We offer both services."
            }
          },
          {
            "@type": "Question",
            "name": "How many email aliases can I create?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "You can create unlimited email aliases with Forward Email. Use catch-all forwarding to receive email at any address on your domain, or create specific aliases for different purposes."
            }
          },
          {
            "@type": "Question",
            "name": "Does Forward Email work with Gmail?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes! Forward Email works perfectly with Gmail. You can forward emails to your Gmail account and use Gmail's Send Mail As feature to send from your custom domain address."
            }
          },
          {
            "@type": "Question",
            "name": "What DNS records do I need to set up?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "You need to add two MX records pointing to our servers and one TXT record containing your forwarding rules. We also recommend adding SPF, DKIM, and DMARC records for better deliverability."
            }
          }
        ]
      }

